# ============================================================
# Lift Commerce Integration - Production Environment Variables
# ============================================================
# IMPORTANT: This file contains production credentials
# DO NOT commit to version control

# Lift Commerce API Credentials (PRODUCTION)
LIFT_API_KEY=
LIFT_CUSTOMER_ID=
LIFT_INTEGRATION_ID=
LIFT_API_BASE_URL=

# Odoo Configuration (PRODUCTION)
ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_API_KEY=

# Database Configuration (AWS RDS)
DB_HOST=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

# Dashboard Authentication
# Username for dashboard login
ADMIN_USERNAME=
# SHA256 hash of the dashboard password
# Generate: echo -n "your_password" | shasum -a 256
ADMIN_PASSWORD_HASH=

# Webhook Security
# Secret for authenticating incoming webhooks from Lift Commerce
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=

# Testing Mode
# DRY_RUN=true  → Simulates label creation without calling Lift Commerce API (SAFE TESTING)
# DRY_RUN=false → Creates real labels (PRODUCTION MODE)
DRY_RUN=

# Odoo Tracking Write-back
# When true, webhook will write tracking numbers back to Odoo delivery orders
ODOO_WRITEBACK_ENABLED=
